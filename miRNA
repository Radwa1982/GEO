#!/bin/bash


# 1. Create a directory for the cleaned files
mkdir -p cleaned_fastq

# 2. Loop through all fastq files starting with SRR
for file in SRR*.fastq; do
    basename=$(basename "$file" .fastq)

    echo "----------------------------------------------------"
    echo "Processing sample: $basename"
    echo "----------------------------------------------------"

    fastp -i "$file" \
          -o "cleaned_fastq/${basename}_cleaned.fastq.gz" \
          --length_required 15 \
          -h "cleaned_fastq/${basename}.html" \
          -j "cleaned_fastq/${basename}.json"
done

~
