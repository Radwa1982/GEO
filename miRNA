THREADS=8

# Create directories if they don't exist
mkdir -p "$OUTPUT_DIR" "$LOG_DIR"

# Loop over FASTQ files in the input directory
for fq in "$INPUT_DIR"/*.fastq; do
    sample=$(basename "$fq" .fastq)
    echo "=== Processing $sample ==="

    # Align with Bowtie (no decompression needed for .fastq files)
    bowtie -p "$THREADS" -q -n 2 -l 15 -k 1 -S "$INDEX" "$fq" 2> "$LOG_DIR/${sample}.bowtie.log" | \
    samtools view -bS - | \
    samtools sort -@ "$THREADS" -o "$OUTPUT_DIR/${sample}.sorted.bam"

    # Index the BAM file
    samtools index "$OUTPUT_DIR/${sample}.sorted.bam"

    echo "=== Finished $sample ==="
done
